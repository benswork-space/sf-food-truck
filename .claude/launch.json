{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const d='/tmp/ftf-dist';process.cwd=()=>d;const http=require('http'),fs=require('fs'),path=require('path');const mime={'.html':'text/html','.js':'application/javascript','.css':'text/css','.woff':'font/woff','.woff2':'font/woff2','.png':'image/png','.svg':'image/svg+xml'};http.createServer((req,res)=>{let p=path.join(d,req.url==='/'?'index.html':req.url);fs.readFile(p,(err,data)=>{if(err){fs.readFile(path.join(d,'index.html'),(e2,d2)=>{if(e2){res.writeHead(404);res.end('Not found');return}res.writeHead(200,{'Content-Type':'text/html'});res.end(d2)})}else{const ext=path.extname(p);res.writeHead(200,{'Content-Type':mime[ext]||'application/octet-stream'});res.end(data)}})}).listen(5199,()=>console.log('Local: http://localhost:5199/'))"],
      "port": 5199
    }
  ]
}
